<?xml version="1.0"?>
<robot name="robot_cuadrupedo">

  <material name="azul"><color rgba="0.1 0.4 0.8 1.0"/></material>
  <material name="rojo"><color rgba="0.8 0.1 0.1 1.0"/></material>
  <material name="negro"><color rgba="0.15 0.15 0.15 1.0"/></material>

  <link name="base_link">
    <inertial>
      <mass value="0.550"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.002"/>
    </inertial>
    <visual>
      <geometry><box size="0.20 0.12 0.05"/></geometry>
      <material name="azul"/>
    </visual>
    <collision>
      <geometry><box size="0.20 0.12 0.05"/></geometry>
    </collision>
  </link>

  <link name="delantera_derecha_thigh">
    <inertial>
      <mass value="0.015"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.025" rpy="0 0 0"/>
      <geometry><cylinder radius="0.01" length="0.05"/></geometry>
      <material name="negro"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.025" rpy="0 0 0"/>
      <geometry><cylinder radius="0.01" length="0.05"/></geometry>
    </collision>
  </link>

  <joint name="base_to_delantera_derecha_thigh" type="revolute">
    <parent link="base_link"/>
    <child link="delantera_derecha_thigh"/>
    <origin xyz="0.08 -0.07 0" rpy="0 0 -0.7854"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="0.215" velocity="6.0"/>
  </joint>

